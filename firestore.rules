rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if resource.data.status == 'published'
                  || request.auth.token.email == 'udithasuranjith@icloud.com';
      allow write: if request.auth.token.email == 'udithasuranjith@icloud.com';
    }

    match /analytics/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth.token.email == 'udithasuranjith@icloud.com';
    }

    match /config/{docId} {
      // Public read so homepage can fetch sections without auth
      allow read: if true;
      allow write: if request.auth.token.email == 'udithasuranjith@icloud.com';
    }
  }
}
