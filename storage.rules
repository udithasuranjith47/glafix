rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Anyone can view images and videos (needed for blog post media)
      allow read: if true;

      // Only the admin email can upload new files or replace existing ones
      allow create, update: if request.auth.token.email == 'udithasuranjith@icloud.com'
        && request.resource.size < 200 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));

      // Only the admin email can delete files
      allow delete: if request.auth.token.email == 'udithasuranjith@icloud.com';
    }
  }
}
